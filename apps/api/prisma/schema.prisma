generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchDayStatus {
  OPEN
  CLOSED
  IN_PROGRESS
  FINISHED
}

enum TeamType {
  NATIONAL_TEAM
  CLUB
}

enum CompetitionSeasonStatus {
  DRAFT
  ACTIVE
  FINISHED
  ARCHIVED
}

enum StageType {
  LEAGUE
  GROUP
  KNOCKOUT
}

enum RoundStatus {
  SCHEDULED
  ACTIVE
  FINISHED
}

enum PoolMembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum PoolMembershipStatus {
  ACTIVE
  INACTIVE
  REMOVED
}

enum ProviderEntityType {
  COMPETITION
  COMPETITION_SEASON
  STAGE
  ROUND
  TEAM
  MATCH
}

enum ScoreType {
  EXACT_SCORE
  RESULT
  ONE_TEAM_GOALS
  MISS
}

enum KnockoutStage {
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum KnockoutGenerationMode {
  PROVISIONAL
  OFFICIAL
}

enum KnockoutGenerationStatus {
  ACTIVE
  LOCKED
  RESET
}

enum SyncStatus {
  SUCCESS
  FAILED
}

enum ProviderSyncType {
  TEAMS
  SCHEDULE
  RESULTS
  STANDINGS
}

enum ProviderSyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
  DRY_RUN
}

enum SyncQuarantineReason {
  INVALID_PAYLOAD
  DUPLICATE_EXTERNAL_ID
  AMBIGUOUS_NAME
  MISSING_MAPPING
  INVALID_REFERENCE
  CONFLICT
}

enum AuditAction {
  USER_BLOCKED
  USER_UNBLOCKED
  USER_ROLE_CHANGED
  PASSWORD_RESET
  MANUAL_SYNC
  MATCH_ADJUSTED
  MATCH_OVERRIDE_SET
  MATCH_OVERRIDE_REMOVED
  SETTING_UPDATED
  SEASON_UPDATED
  ROUND_UPDATED
  SYNC_REQUESTED
  MAPPING_RESOLVED
  RULE_SET_ASSIGNED
  USER_SESSION_REVOKED
  JOB_QUEUED
  JOB_PAUSED
  JOB_RETRIED
}

enum AdminOperationStatus {
  PREVIEW
  RUNNING
  COMPLETED
  FAILED
  CONSUMED
}

enum AdminJobStatus {
  QUEUED
  RUNNING
  PAUSED
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id                      String                         @id @default(cuid())
  username                String                         @unique
  usernameLower           String                         @unique
  nickname                String
  avatarUrl               String?
  passwordHash            String
  sessionVersion          Int                            @default(1)
  role                    UserRole                       @default(USER)
  status                  UserStatus                     @default(ACTIVE)
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  predictions             Prediction[]
  scores                  PredictionScore[]
  auditLogs               AdminAuditLog[]                @relation("AdminAuditActor")
  knockoutBrackets        KnockoutBracket[]
  knockoutScores          KnockoutPredictionScore[]
  groupSimulations        KnockoutGroupSimulationScore[]
  poolMemberships         PoolMembership[]
  matchOverrides          MatchOverride[]
  scoreAudits             ScoreRecomputationAudit[]
  achievements            UserAchievement[]
  streaks                 Streak[]
  rankingMovements        RankingMovement[]
  rankingVisits           UserPoolSeasonVisit[]
  notifications           NotificationInbox[]
  notificationPreferences NotificationPreference[]

  @@index([role, status])
  @@index([nickname])
}

model Competition {
  id           String              @id @default(cuid())
  slug         String              @unique
  name         String
  capabilities Json?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  seasons      CompetitionSeason[]

  @@index([name])
}

model CompetitionSeason {
  id                     String                  @id @default(cuid())
  competitionId          String
  slug                   String
  name                   String
  year                   Int?
  timezone               String
  status                 CompetitionSeasonStatus @default(DRAFT)
  startsAt               DateTime?
  endsAt                 DateTime?
  capabilities           Json?
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  competition            Competition             @relation(fields: [competitionId], references: [id])
  stages                 Stage[]
  rounds                 Round[]
  teams                  SeasonTeam[]
  matchDays              MatchDay[]
  matches                Match[]
  knockoutFixtures       KnockoutFixture[]
  knockoutGenerations    KnockoutGeneration[]
  poolSeasons            PoolSeason[]
  providerMappings       ProviderEntityMapping[]
  rankingSnapshots       RankingSnapshot[]
  scoringRuleVersions    ScoringRuleSetVersion[]
  tieBreakerRuleSets     TieBreakerRuleSet[]
  achievementDefinitions AchievementDefinition[]
  providerSyncRuns       ProviderSyncRun[]
  providerSyncLocks      ProviderSyncLock[]
  syncQuarantines        SyncQuarantine[]
  teamProfileSnapshots   TeamProfileSnapshot[]

  @@unique([competitionId, slug])
  @@index([competitionId, status])
  @@index([status, startsAt])
}

model Stage {
  id        String            @id @default(cuid())
  seasonId  String
  slug      String
  name      String
  type      StageType
  order     Int
  metadata  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  season    CompetitionSeason @relation(fields: [seasonId], references: [id])
  rounds    Round[]
  matches   Match[]

  @@unique([seasonId, slug])
  @@unique([seasonId, order])
  @@index([seasonId, type])
}

model Round {
  id               String            @id @default(cuid())
  seasonId         String
  stageId          String
  name             String
  order            Int
  status           RoundStatus       @default(SCHEDULED)
  startsAt         DateTime?
  endsAt           DateTime?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  season           CompetitionSeason @relation(fields: [seasonId], references: [id])
  stage            Stage             @relation(fields: [stageId], references: [id])
  matches          Match[]
  rankingSnapshots RankingSnapshot[]
  rankingMovements RankingMovement[]

  @@unique([stageId, order])
  @@index([seasonId, status, startsAt])
  @@index([stageId, status, startsAt])
}

model Team {
  id                    String            @id @default(cuid())
  externalId            String            @unique
  name                  String
  code                  String?
  flagUrl               String?
  type                  TeamType?
  crestUrl              String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  homeMatches           Match[]           @relation("HomeTeam")
  awayMatches           Match[]           @relation("AwayTeam")
  fifaRank              Int?
  knockoutHomeFixtures  KnockoutFixture[] @relation("KnockoutHomeTeam")
  knockoutAwayFixtures  KnockoutFixture[] @relation("KnockoutAwayTeam")
  knockoutWinners       KnockoutFixture[] @relation("KnockoutWinnerTeam")
  knockoutPickHome      KnockoutPick[]    @relation("KnockoutPickHomeTeam")
  knockoutPickAway      KnockoutPick[]    @relation("KnockoutPickAwayTeam")
  knockoutPickAdvancing KnockoutPick[]    @relation("KnockoutPickAdvancingTeam")
  seasons               SeasonTeam[]
  profileSnapshots      TeamProfileSnapshot[]

  @@index([name])
  @@index([code])
  @@index([fifaRank])
}

model SeasonTeam {
  id        String            @id @default(cuid())
  seasonId  String
  teamId    String
  seed      Int?
  groupName String?
  metadata  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  season    CompetitionSeason @relation(fields: [seasonId], references: [id])
  team      Team              @relation(fields: [teamId], references: [id])

  @@unique([seasonId, teamId])
  @@index([teamId, seasonId])
  @@index([seasonId, groupName])
}

model TeamProfileSnapshot {
  id             String            @id @default(cuid())
  seasonId       String
  teamId         String
  provider       String
  externalTeamId String
  state          String?
  sourceUrl      String
  collectedAt    DateTime
  checksum       String
  statistics     Json
  athletes       Json
  matches        Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  season         CompetitionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team           Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId, provider])
  @@unique([seasonId, provider, externalTeamId])
  @@index([teamId, collectedAt])
  @@index([seasonId, collectedAt])
}

model Pool {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  isPublic    Boolean          @default(false)
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships PoolMembership[]
  seasons     PoolSeason[]

  @@index([name])
}

model PoolMembership {
  id        String               @id @default(cuid())
  poolId    String
  userId    String
  role      PoolMembershipRole   @default(MEMBER)
  status    PoolMembershipStatus @default(ACTIVE)
  joinedAt  DateTime             @default(now())
  metadata  Json?
  updatedAt DateTime             @updatedAt
  pool      Pool                 @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId])
  @@index([poolId, status])
  @@index([userId, status])
}

model PoolSeason {
  id                         String                         @id @default(cuid())
  poolId                     String
  seasonId                   String
  scoringRuleSetId           String?
  scoringRuleSetVersionId    String?
  tieBreakerRuleSetId        String?
  scoreableFromRound         Int?
  scoreableFrom              DateTime?
  startsAtRound              Int?
  historicalMatchesScoreable Boolean                        @default(false)
  metadata                   Json?
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  pool                       Pool                           @relation(fields: [poolId], references: [id])
  season                     CompetitionSeason              @relation(fields: [seasonId], references: [id])
  scoringRuleSet             ScoringRuleSet?                @relation(fields: [scoringRuleSetId], references: [id])
  scoringRuleSetVersion      ScoringRuleSetVersion?         @relation(fields: [scoringRuleSetVersionId], references: [id])
  tieBreakerRuleSet          TieBreakerRuleSet?             @relation(fields: [tieBreakerRuleSetId], references: [id])
  predictions                Prediction[]
  predictionScores           PredictionScore[]
  rankingSnapshots           RankingSnapshot[]
  knockoutBrackets           KnockoutBracket[]
  knockoutPicks              KnockoutPick[]
  knockoutGroupSimulations   KnockoutGroupSimulationScore[]
  knockoutPredictionScores   KnockoutPredictionScore[]
  scoreAudits                ScoreRecomputationAudit[]
  userAchievements           UserAchievement[]
  streaks                    Streak[]
  rankingMovements           RankingMovement[]
  rankingVisits              UserPoolSeasonVisit[]
  notifications              NotificationInbox[]
  notificationPreferences    NotificationPreference[]

  @@unique([poolId, seasonId])
  @@index([seasonId])
  @@index([scoringRuleSetId])
  @@index([scoringRuleSetVersionId])
  @@index([tieBreakerRuleSetId])
  @@index([scoreableFrom])
}

model ScoringRuleSet {
  id          String       @id @default(cuid())
  key         String
  name        String
  version     Int
  rules       Json
  tieBreakers Json?
  effectiveAt DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())
  poolSeasons PoolSeason[]

  @@unique([key, version])
  @@index([effectiveAt])
}

model ScoringRuleSetVersion {
  id                       String                    @id @default(cuid())
  key                      String
  name                     String
  version                  Int
  rules                    Json
  checksum                 String
  effectiveAt              DateTime?
  createdAt                DateTime                  @default(now())
  seasonId                 String?
  season                   CompetitionSeason?        @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  poolSeasons              PoolSeason[]
  predictionScores         PredictionScore[]
  knockoutPredictionScores KnockoutPredictionScore[]
  scoreAudits              ScoreRecomputationAudit[]

  @@unique([key, version])
  @@unique([checksum])
  @@index([seasonId, effectiveAt])
}

model TieBreakerRuleSet {
  id                   String             @id @default(cuid())
  key                  String
  name                 String
  version              Int
  criteria             Json
  allowSharedPositions Boolean            @default(true)
  checksum             String
  effectiveAt          DateTime?
  createdAt            DateTime           @default(now())
  seasonId             String?
  season               CompetitionSeason? @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  poolSeasons          PoolSeason[]

  @@unique([key, version])
  @@unique([checksum])
  @@index([seasonId, effectiveAt])
}

model ProviderEntityMapping {
  id          String             @id @default(cuid())
  provider    String
  entityType  ProviderEntityType
  externalId  String
  internalId  String
  seasonId    String?
  sourceUrl   String?
  collectedAt DateTime?
  checksum    String?
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  season      CompetitionSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@unique([provider, entityType, externalId])
  @@index([seasonId, entityType])
  @@index([entityType, internalId])
}

model MatchDay {
  id                 String             @id @default(cuid())
  date               DateTime
  firstMatchStartsAt DateTime
  predictionsCloseAt DateTime
  status             MatchDayStatus     @default(OPEN)
  seasonId           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  matches            Match[]
  season             CompetitionSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@unique([seasonId, date])
  @@index([status, predictionsCloseAt])
  @@index([firstMatchStartsAt])
  @@index([seasonId, date])
  @@index([seasonId, status, predictionsCloseAt])
}

model Match {
  id                 String                         @id @default(cuid())
  externalId         String                         @unique
  matchDayId         String
  seasonId           String?
  stageId            String?
  roundId            String?
  homeTeamId         String
  awayTeamId         String
  startsAt           DateTime
  predictionClosesAt DateTime?
  status             MatchStatus                    @default(SCHEDULED)
  homeScore          Int?
  awayScore          Int?
  finalHomeScore     Int?
  finalAwayScore     Int?
  rawPayload         Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  matchDay           MatchDay                       @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  season             CompetitionSeason?             @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  stage              Stage?                         @relation(fields: [stageId], references: [id], onDelete: SetNull)
  round              Round?                         @relation(fields: [roundId], references: [id], onDelete: SetNull)
  homeTeam           Team                           @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam           Team                           @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions        Prediction[]
  scores             PredictionScore[]
  groupSimulations   KnockoutGroupSimulationScore[]
  manualOverride     MatchOverride?

  @@index([matchDayId, startsAt])
  @@index([status, startsAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([seasonId, status, startsAt])
  @@index([seasonId, roundId, status, startsAt])
  @@index([seasonId, roundId, startsAt])
  @@index([stageId, startsAt])
  @@index([roundId, startsAt])
}

model Prediction {
  id                 String           @id @default(cuid())
  userId             String
  matchId            String
  poolSeasonId       String?
  predictedHomeScore Int
  predictedAwayScore Int
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  match              Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  score              PredictionScore?
  poolSeason         PoolSeason?      @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)

  @@unique([userId, matchId])
  @@unique([poolSeasonId, userId, matchId])
  @@index([matchId])
  @@index([userId])
  @@index([poolSeasonId, matchId])
  @@index([poolSeasonId, userId])
}

model PredictionScore {
  id                      String                @id @default(cuid())
  predictionId            String                @unique
  matchId                 String
  userId                  String
  poolSeasonId            String?
  points                  Int
  scoreType               ScoreType
  isFinal                 Boolean               @default(false)
  calculatedAt            DateTime              @default(now())
  scoringRuleSetVersionId String
  scoringVersion          Int
  breakdown               Json
  calculationKey          String
  resultRevision          String
  prediction              Prediction            @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  match                   Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  poolSeason              PoolSeason?           @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)
  scoringRuleSetVersion   ScoringRuleSetVersion @relation(fields: [scoringRuleSetVersionId], references: [id], onDelete: Restrict)

  @@unique([predictionId, calculationKey])
  @@index([userId, isFinal])
  @@index([matchId, isFinal])
  @@index([points])
  @@index([poolSeasonId, userId, isFinal])
  @@index([poolSeasonId, matchId, isFinal])
  @@index([scoringRuleSetVersionId, scoringVersion])
}

model KnockoutFixture {
  id             String                    @id @default(cuid())
  seasonId       String?
  matchNumber    Int                       @unique
  stage          KnockoutStage
  startsAt       DateTime
  homeSource     String
  awaySource     String
  homeTeamId     String?
  awayTeamId     String?
  winnerTeamId   String?
  status         MatchStatus               @default(SCHEDULED)
  homeScore      Int?
  awayScore      Int?
  finalHomeScore Int?
  finalAwayScore Int?
  rawPayload     Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  homeTeam       Team?                     @relation("KnockoutHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team?                     @relation("KnockoutAwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam     Team?                     @relation("KnockoutWinnerTeam", fields: [winnerTeamId], references: [id])
  season         CompetitionSeason?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  picks          KnockoutPick[]
  scores         KnockoutPredictionScore[]

  @@index([stage, startsAt])
  @@index([status, startsAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([seasonId, stage, status, startsAt])
}

model KnockoutGeneration {
  id               String                         @id @default(cuid())
  seasonId         String?
  sequence         Int                            @unique
  mode             KnockoutGenerationMode
  status           KnockoutGenerationStatus       @default(ACTIVE)
  closesAt         DateTime?
  resetAt          DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  brackets         KnockoutBracket[]
  groupSimulations KnockoutGroupSimulationScore[]
  season           CompetitionSeason?             @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([mode, status])
  @@index([closesAt])
  @@index([seasonId, mode, status])
}

model KnockoutBracket {
  id           String             @id @default(cuid())
  userId       String
  generationId String
  poolSeasonId String?
  submittedAt  DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation   KnockoutGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  poolSeason   PoolSeason?        @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)
  picks        KnockoutPick[]

  @@unique([userId, generationId])
  @@index([generationId, submittedAt])
  @@index([userId])
  @@index([poolSeasonId, userId])
}

model KnockoutPick {
  id                 String                   @id @default(cuid())
  bracketId          String
  fixtureId          String
  poolSeasonId       String?
  homeTeamId         String
  awayTeamId         String
  advancingTeamId    String
  predictedHomeScore Int
  predictedAwayScore Int
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  bracket            KnockoutBracket          @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  fixture            KnockoutFixture          @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  homeTeam           Team                     @relation("KnockoutPickHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam           Team                     @relation("KnockoutPickAwayTeam", fields: [awayTeamId], references: [id])
  advancingTeam      Team                     @relation("KnockoutPickAdvancingTeam", fields: [advancingTeamId], references: [id])
  score              KnockoutPredictionScore?
  poolSeason         PoolSeason?              @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)

  @@unique([bracketId, fixtureId])
  @@index([fixtureId])
  @@index([advancingTeamId])
  @@index([poolSeasonId, bracketId])
}

model KnockoutGroupSimulationScore {
  id                 String             @id @default(cuid())
  userId             String
  generationId       String
  matchId            String
  poolSeasonId       String?
  predictedHomeScore Int
  predictedAwayScore Int
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation         KnockoutGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  match              Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  poolSeason         PoolSeason?        @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)

  @@unique([userId, generationId, matchId])
  @@index([generationId])
  @@index([matchId])
  @@index([userId])
  @@index([poolSeasonId, userId])
}

model KnockoutPredictionScore {
  id                      String                @id @default(cuid())
  pickId                  String                @unique
  fixtureId               String
  userId                  String
  poolSeasonId            String?
  points                  Int
  scoreType               ScoreType
  isFinal                 Boolean               @default(false)
  calculatedAt            DateTime              @default(now())
  scoringRuleSetVersionId String
  scoringVersion          Int
  breakdown               Json
  calculationKey          String
  resultRevision          String
  pick                    KnockoutPick          @relation(fields: [pickId], references: [id], onDelete: Cascade)
  fixture                 KnockoutFixture       @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  poolSeason              PoolSeason?           @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)
  scoringRuleSetVersion   ScoringRuleSetVersion @relation(fields: [scoringRuleSetVersionId], references: [id], onDelete: Restrict)

  @@unique([pickId, calculationKey])
  @@index([userId, isFinal])
  @@index([fixtureId, isFinal])
  @@index([points])
  @@index([poolSeasonId, userId, isFinal])
  @@index([scoringRuleSetVersionId, scoringVersion])
}

model RankingSnapshot {
  id             String                @id @default(cuid())
  userId         String
  seasonId       String?
  poolSeasonId   String?
  roundId        String?
  points         Int
  finalPoints    Int
  exactScores    Int
  resultHits     Int
  oneGoalHits    Int
  misses         Int                   @default(0)
  rank           Int
  hasLiveData    Boolean               @default(false)
  snapshotKey    String
  sourceRevision String
  calculatedAt   DateTime              @default(now())
  season         CompetitionSeason?    @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  poolSeason     PoolSeason?           @relation(fields: [poolSeasonId], references: [id], onDelete: SetNull)
  round          Round?                @relation(fields: [roundId], references: [id], onDelete: SetNull)
  movementsFrom  RankingMovement[]     @relation("MovementFromSnapshot")
  movementsTo    RankingMovement[]     @relation("MovementToSnapshot")
  visits         UserPoolSeasonVisit[]

  @@unique([poolSeasonId, userId, snapshotKey])
  @@index([rank])
  @@index([points])
  @@index([userId])
  @@index([calculatedAt])
  @@index([seasonId, roundId, calculatedAt])
  @@index([poolSeasonId, roundId, calculatedAt])
}

model ScoreRecomputationAudit {
  id                      String                @id @default(cuid())
  poolSeasonId            String
  userId                  String
  targetType              String
  targetId                String
  sourceRevision          String
  scoringRuleSetVersionId String
  before                  Json?
  after                   Json?
  reason                  String
  idempotencyKey          String                @unique
  createdAt               DateTime              @default(now())
  poolSeason              PoolSeason            @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scoringRuleSetVersion   ScoringRuleSetVersion @relation(fields: [scoringRuleSetVersionId], references: [id], onDelete: Restrict)

  @@index([poolSeasonId, targetType, targetId, createdAt])
  @@index([userId, createdAt])
}

model AchievementDefinition {
  id          String             @id @default(cuid())
  key         String
  version     Int
  name        String
  description String
  rarity      String
  criteria    Json
  checksum    String             @unique
  seasonId    String?
  createdAt   DateTime           @default(now())
  season      CompetitionSeason? @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  awards      UserAchievement[]

  @@unique([key, version])
  @@index([seasonId, key])
}

model UserAchievement {
  id             String                @id @default(cuid())
  poolSeasonId   String
  userId         String
  definitionId   String
  idempotencyKey String                @unique
  progress       Json
  isProvisional  Boolean               @default(false)
  achievedAt     DateTime?
  revokedAt      DateTime?
  sourceRevision String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  poolSeason     PoolSeason            @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  definition     AchievementDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)

  @@unique([poolSeasonId, userId, definitionId])
  @@index([poolSeasonId, userId, achievedAt])
}

model Streak {
  id             String     @id @default(cuid())
  poolSeasonId   String
  userId         String
  type           String
  currentCount   Int
  bestCount      Int
  lastEventKey   String?
  sourceRevision String
  updatedAt      DateTime   @updatedAt
  poolSeason     PoolSeason @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolSeasonId, userId, type])
  @@index([poolSeasonId, type, bestCount])
}

model RankingMovement {
  id             String          @id @default(cuid())
  poolSeasonId   String
  roundId        String?
  userId         String
  fromSnapshotId String
  toSnapshotId   String
  fromRank       Int
  toRank         Int
  delta          Int
  isProvisional  Boolean         @default(false)
  idempotencyKey String          @unique
  createdAt      DateTime        @default(now())
  poolSeason     PoolSeason      @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  round          Round?          @relation(fields: [roundId], references: [id], onDelete: SetNull)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromSnapshot   RankingSnapshot @relation("MovementFromSnapshot", fields: [fromSnapshotId], references: [id], onDelete: Cascade)
  toSnapshot     RankingSnapshot @relation("MovementToSnapshot", fields: [toSnapshotId], references: [id], onDelete: Cascade)

  @@unique([poolSeasonId, userId, fromSnapshotId, toSnapshotId])
  @@index([poolSeasonId, userId, createdAt])
}

model UserPoolSeasonVisit {
  id                 String           @id @default(cuid())
  poolSeasonId       String
  userId             String
  lastSeenSnapshotId String?
  lastSeenAt         DateTime         @default(now())
  poolSeason         PoolSeason       @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenSnapshot   RankingSnapshot? @relation(fields: [lastSeenSnapshotId], references: [id], onDelete: SetNull)

  @@unique([poolSeasonId, userId])
  @@index([userId, lastSeenAt])
}

model NotificationInbox {
  id             String     @id @default(cuid())
  poolSeasonId   String
  userId         String
  type           String
  title          String
  body           String
  data           Json?
  idempotencyKey String     @unique
  isProvisional  Boolean    @default(false)
  availableAt    DateTime   @default(now())
  readAt         DateTime?
  createdAt      DateTime   @default(now())
  poolSeason     PoolSeason @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([poolSeasonId, userId, readAt, availableAt])
}

model NotificationPreference {
  id                String     @id @default(cuid())
  poolSeasonId      String
  userId            String
  inAppEnabled      Boolean    @default(true)
  pushEnabled       Boolean    @default(false)
  emailEnabled      Boolean    @default(false)
  quietHoursEnabled Boolean    @default(false)
  quietHoursStart   String?
  quietHoursEnd     String?
  timezone          String     @default("America/Sao_Paulo")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  poolSeason        PoolSeason @relation(fields: [poolSeasonId], references: [id], onDelete: Cascade)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolSeasonId, userId])
}

model ApiSyncLog {
  id         String     @id @default(cuid())
  status     SyncStatus
  source     String
  message    String?
  details    Json?
  startedAt  DateTime
  finishedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([status, createdAt])
  @@index([source, createdAt])
}

model ProviderSyncRun {
  id               String                @id @default(cuid())
  provider         String
  seasonId         String
  type             ProviderSyncType
  idempotencyKey   String
  dryRun           Boolean               @default(false)
  status           ProviderSyncRunStatus @default(RUNNING)
  source           String
  checksum         String?
  fetchedCount     Int                   @default(0)
  insertedCount    Int                   @default(0)
  updatedCount     Int                   @default(0)
  unchangedCount   Int                   @default(0)
  quarantinedCount Int                   @default(0)
  requestedById    String?
  errorCode        String?
  errorMessage     String?
  startedAt        DateTime              @default(now())
  finishedAt       DateTime?
  createdAt        DateTime              @default(now())
  season           CompetitionSeason     @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  quarantines      SyncQuarantine[]

  @@unique([provider, seasonId, type, idempotencyKey])
  @@index([seasonId, type, startedAt])
  @@index([provider, status, startedAt])
}

model ProviderSyncLock {
  key        String            @id
  provider   String
  seasonId   String
  type       ProviderSyncType
  ownerId    String
  acquiredAt DateTime          @default(now())
  expiresAt  DateTime
  updatedAt  DateTime          @updatedAt
  season     CompetitionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([provider, seasonId, type])
  @@index([expiresAt])
}

model SyncQuarantine {
  id           String               @id @default(cuid())
  runId        String
  seasonId     String
  provider     String
  type         ProviderSyncType
  externalId   String?
  reason       SyncQuarantineReason
  message      String
  payload      Json
  checksum     String
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime             @default(now())
  run          ProviderSyncRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  season       CompetitionSeason    @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  @@index([seasonId, reason, resolvedAt])
  @@index([runId, createdAt])
  @@index([provider, externalId])
}

model MatchOverride {
  id            String    @id @default(cuid())
  matchId       String    @unique
  actorId       String?
  justification String
  values        Json
  before        Json
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  removedAt     DateTime?
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  actor         User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([active, updatedAt])
  @@index([actorId, updatedAt])
}

model AdminAuditLog {
  id             String      @id @default(cuid())
  actorId        String?
  action         AuditAction
  targetId       String?
  requestId      String?
  seasonId       String?
  poolSeasonId   String?
  justification  String?
  idempotencyKey String?     @unique
  origin         String?
  before         Json?
  after          Json?
  details        Json?
  createdAt      DateTime    @default(now())
  actor          User?       @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetId])
  @@index([seasonId, poolSeasonId, createdAt])
  @@index([requestId])
}

model AdminOperation {
  id               String               @id @default(cuid())
  actorId          String
  action           String
  targetType       String
  targetId         String?
  seasonId         String?
  poolSeasonId     String?
  requestId        String
  idempotencyKey   String               @unique
  requestHash      String
  status           AdminOperationStatus
  justification    String
  preview          Json?
  affectedCount    Int                  @default(0)
  confirmationHash String?
  expiresAt        DateTime?
  result           Json?
  errorCode        String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  completedAt      DateTime?

  @@index([actorId, createdAt])
  @@index([seasonId, poolSeasonId, createdAt])
  @@index([status, expiresAt])
}

model AdminJob {
  id                      String         @id @default(cuid())
  type                    String
  status                  AdminJobStatus @default(QUEUED)
  seasonId                String
  poolSeasonId            String?
  ruleSetVersionId        String?
  requestedById           String
  requestId               String
  justification           String
  idempotencyKey          String         @unique
  payload                 Json
  preview                 Json
  affectedCount           Int            @default(0)
  processedCount          Int            @default(0)
  attempts                Int            @default(0)
  maxAttempts             Int            @default(3)
  pauseRequested          Boolean        @default(false)
  result                  Json?
  errorCode               String?
  errorMessage            String?
  createdAt               DateTime       @default(now())
  startedAt               DateTime?
  finishedAt              DateTime?
  updatedAt               DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([seasonId, poolSeasonId, createdAt])
  @@index([type, status, createdAt])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model OutboxEvent {
  id             String    @id @default(cuid())
  type           String
  seasonId       String
  poolSeasonId   String?
  version        Int       @default(1)
  payload        Json
  occurredAt     DateTime  @default(now())
  publishedAt    DateTime?
  attempts       Int       @default(0)
  lastError      String?
  idempotencyKey String?   @unique
  createdAt      DateTime  @default(now())

  @@index([publishedAt, occurredAt])
  @@index([seasonId, occurredAt])
  @@index([poolSeasonId, occurredAt])
  @@index([type, occurredAt])
}

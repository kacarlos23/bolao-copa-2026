{
  "name": "@bolao/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "lint": "eslint src prisma --ext .ts",
    "test": "vitest run",
    "test:contract": "vitest run src/app.test.ts src/modules/generic-routes.contract.test.ts src/realtime/sse.test.ts src/runtime/shutdown.test.ts src/middleware/auth.test.ts",
    "test:integration:vitest": "vitest run --config vitest.integration.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "backfill:world-cup-2026": "tsx prisma/backfill-world-cup-2026.ts",
    "backfill:stage7-engagement": "tsx src/scripts/backfill-stage7-engagement.ts",
    "load:brasileirao-2026": "tsx src/scripts/load-brasileirao-2026.ts",
    "collect:sudamericana-2026": "tsx src/scripts/collect-sudamericana-2026.ts",
    "load:sudamericana-2026": "tsx src/scripts/load-sudamericana-2026.ts",
    "reconcile:sudamericana-2026": "tsx src/scripts/reconcile-sudamericana-2026.ts",
    "reconcile:cbf-2026": "tsx src/scripts/reconcile-cbf-2026.ts",
    "sync:cbf-team-profiles": "tsx src/scripts/sync-cbf-team-profiles.ts",
    "scrape:ge-scores": "tsx src/scripts/scrape-ge-scores.ts",
    "scrape:ge-scores:once": "tsx src/scripts/scrape-ge-scores.ts --once",
    "scrape:ge-scores:watch": "tsx src/scripts/scrape-ge-scores.ts --watch"
  },
  "dependencies": {
    "@bolao/shared": "0.1.0",
    "@prisma/client": "^6.19.0",
    "argon2": "^0.41.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "sharp": "^0.35.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.0",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.19.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

{
  "name": "bolao-copa-2026",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm --workspace @bolao/api run dev",
    "dev:web": "npm --workspace @bolao/web run dev",
    "build": "npm-run-all build:shared build:api build:web",
    "build:api": "npm --workspace @bolao/api run build",
    "build:shared": "npm --workspace @bolao/shared run build",
    "build:web": "npm --workspace @bolao/web run build",
    "lint": "npm-run-all lint:*",
    "lint:api": "npm --workspace @bolao/api run lint",
    "lint:web": "npm --workspace @bolao/web run lint",
    "lint:shared": "npm --workspace @bolao/shared run lint",
    "format": "prettier --write .",
    "test": "npm-run-all test:shared test:api",
    "test:api": "npm --workspace @bolao/api run test",
    "test:shared": "npm --workspace @bolao/shared run test",
    "prisma:generate": "npm --workspace @bolao/api run prisma:generate",
    "prisma:migrate": "npm --workspace @bolao/api run prisma:migrate",
    "seed": "npm --workspace @bolao/api run seed",
    "scrape:ge-scores": "npm --workspace @bolao/api run scrape:ge-scores",
    "scrape:ge-scores:once": "npm --workspace @bolao/api run scrape:ge-scores:once",
    "sync:fifa-squads": "node scripts/sync-fifa-squads.mjs",
    "backup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\backup-postgres.ps1",
    "restore": "powershell -ExecutionPolicy Bypass -File .\\scripts\\restore-postgres.ps1",
    "postgres:start": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-project-postgres.ps1",
    "postgres:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-project-postgres.ps1",
    "postgres:status": "powershell -ExecutionPolicy Bypass -File .\\scripts\\status-project-postgres.ps1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "expo-linking": "~8.0.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-reanimated": "^4.1.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}

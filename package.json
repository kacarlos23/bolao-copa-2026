{
  "name": "bolao-copa-2026",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm --workspace @bolao/api run dev",
    "dev:web": "npm --workspace @bolao/web run dev",
    "build": "npm-run-all build:shared build:api build:web",
    "build:api": "npm --workspace @bolao/api run build",
    "build:shared": "npm --workspace @bolao/shared run build",
    "build:web": "npm --workspace @bolao/web run build",
    "lint": "npm-run-all lint:*",
    "lint:api": "npm --workspace @bolao/api run lint",
    "lint:docs": "node scripts/check-markdown-links.mjs",
    "lint:preservation": "node scripts/check-preservation-artifacts.mjs",
    "lint:web": "npm --workspace @bolao/web run lint",
    "lint:shared": "npm --workspace @bolao/shared run lint",
    "format": "prettier --write .",
    "test": "npm-run-all test:preservation test:shared test:api test:web",
    "test:api": "npm run build:shared && npm --workspace @bolao/api run test",
    "test:preservation": "node --test scripts/*.test.mjs",
    "test:migration:constraints": "node scripts/verify-multi-competition-db.mjs",
    "test:shared": "npm --workspace @bolao/shared run test",
    "test:web": "npm --workspace @bolao/web run test",
    "test:e2e": "npm --workspace @bolao/web run test:e2e",
    "test:contract": "npm run build:shared && npm --workspace @bolao/shared run test && npm --workspace @bolao/api run test:contract",
    "test:component": "npm --workspace @bolao/web run test",
    "test:integration": "node scripts/run-postgres-integration.mjs",
    "test:load": "npm --workspace @bolao/api exec -- vitest run src/nonfunctional/load-budget.test.ts",
    "test:budget": "node scripts/check-performance-budget.mjs",
    "test:flakiness": "node scripts/check-flakiness.mjs",
    "test:rehearsal": "node scripts/run-release-rehearsal.mjs",
    "test:go-live-gate": "node --test scripts/verify-go-live-evidence.test.mjs",
    "audit:dependencies": "node scripts/run-dependency-audit.mjs",
    "manifest:release": "node scripts/generate-release-manifest.mjs",
    "gate:pr": "npm-run-all lint test:preservation test:shared test:api test:component test:contract test:go-live-gate audit:dependencies build test:budget",
    "gate:release-candidate": "npm-run-all test:integration test:e2e test:load test:flakiness",
    "gate:migration": "npm run test:rehearsal",
    "gate:go-live": "node scripts/verify-go-live-evidence.mjs",
    "prisma:generate": "npm --workspace @bolao/api run prisma:generate",
    "prisma:migrate": "npm --workspace @bolao/api run prisma:migrate",
    "seed": "npm --workspace @bolao/api run seed",
    "backfill:world-cup-2026": "npm --workspace @bolao/api run backfill:world-cup-2026 --",
    "backfill:stage7-engagement": "npm --workspace @bolao/api run backfill:stage7-engagement",
    "load:brasileirao-2026": "npm --workspace @bolao/api run load:brasileirao-2026",
    "reconcile:cbf-2026": "npm --workspace @bolao/api run reconcile:cbf-2026",
    "scrape:ge-scores": "npm --workspace @bolao/api run scrape:ge-scores",
    "scrape:ge-scores:once": "npm --workspace @bolao/api run scrape:ge-scores:once",
    "scrape:ge-scores:watch": "npm --workspace @bolao/api run scrape:ge-scores:watch",
    "sync:fifa-squads": "node scripts/sync-fifa-squads.mjs",
    "backup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\backup-postgres.ps1",
    "backup:validate": "powershell -ExecutionPolicy Bypass -File .\\scripts\\validate-postgres-backup.ps1",
    "restore": "powershell -ExecutionPolicy Bypass -File .\\scripts\\restore-postgres.ps1",
    "snapshot:copa": "node scripts/copa-snapshot.mjs",
    "snapshot:compare": "node scripts/compare-copa-snapshots.mjs",
    "postgres:start": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-project-postgres.ps1",
    "postgres:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-project-postgres.ps1",
    "postgres:status": "powershell -ExecutionPolicy Bypass -File .\\scripts\\status-project-postgres.ps1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "expo-linking": "~8.0.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-reanimated": "^4.1.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "undici": "6.27.0"
  }
}
